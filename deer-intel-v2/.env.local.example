# Copy this file to .env.local for local development (never commit .env.local).
# In Vercel, set these under Project Settings -> Environment Variables instead.

# Required for the AI Scout feature (app/ai). Without this, AI Scout shows
# an "isn't turned on yet" message and the rest of the app works normally.
# Get a key from https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: override the Claude model AI Scout calls. Defaults to a recent
# Sonnet model if unset. See https://docs.claude.com/en/docs/about-claude/models
# for current model ids.
# ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# Optional: login + cloud sync (Settings -> Account & Cloud Sync). Without these,
# Deer Intel runs in local-only mode and works normally. With them, users can
# create an account and back up / sync their data across devices.
#
# Both values are safe to expose to the browser (the anon key is protected by
# the row-level security policies in supabase/schema.sql). Find them in your
# Supabase project under Settings -> API. Never put the service_role key here.
#
# 1. Create a free project at https://supabase.com
# 2. Run supabase/schema.sql in the project's SQL editor.
# 3. Paste the Project URL and anon/public key below (or into Vercel env vars).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
